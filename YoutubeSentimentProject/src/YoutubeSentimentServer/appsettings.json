{
  "Youtube": {
    "ApiKey": "",
    "PollingIntervalSeconds": 60,
    "MaxResultsPerRequest": 100,
    "MaxPagesPerVideo": 3,
    "RequestTimeoutSeconds": 20,
    "MaxConcurrentVideoRequests": 3,
    "RetryAttempts": 3,
    "RetryBaseDelayMilliseconds": 1000
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Akka": "Information",
      "Akka.Hosting": "Information",
      "YoutubeSentimentServer": "Information",
      "System.Net.Http.HttpClient.IYoutubeApiClient": "Warning"
    }
  },

  "AllowedHosts": "*"
}